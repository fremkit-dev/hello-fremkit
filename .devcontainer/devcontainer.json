{
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Web App",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "npm install && nohup node server.js > /tmp/server.log 2>&1 &",
  "remoteUser": "node"
}
